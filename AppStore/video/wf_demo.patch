+    /// Deterministic attract-mode driver. Steers a gentle weave, but as each cast nears it lines the boat
+    /// up UNDER the deep "cast target" ripple drifting in, then casts straight onto it (so the cast is never
+    /// off). Reels cleanly, spawns leaps from a ripple already on the water, and runs the kraken finale
+    /// (dodge the alternating tentacles + fire harpoons at the eyes). All keyed to worldDist / kraken clock
+    /// so iPhone & watch run the identical sequence in sync.
+    private func demoDrive(_ dt: Double) {
+        if phase == .boating || phase == .launching {
+            boatTargetX = 0.5 + 0.18 * sin(worldDist * 2.4)          // gentle weave between the side obstacles
+        }
+        // Cast: line up under the incoming target ripple, then cast straight up onto it.
+        if phase == .boating, demoStep < demoCastMarks.count {
+            let mark = demoCastMarks[demoStep]
+            if worldDist >= mark - 0.75 {
+                boatTargetX = demoCastX[demoStep]                    // override the weave → align with the ripple
+                if worldDist >= mark, abs(boatX - demoCastX[demoStep]) < 0.05 {
+                    demoStep += 1
+                    startAim()
+                }
+            }
+        }
+        if phase == .reeling { marker = zoneCenter }                // glue to the zone → a clean PERFECT reel
+        if phase == .casting, castReach >= 0.24 { dropCast() }      // a short cast, dropped onto the ripple
+
