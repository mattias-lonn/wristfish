+                leaps.append(Leap(x: h.x, y: h.y, dir: h.x < 0.5 ? 1 : -1))
+            }
+        }
+
+        if !demoKrakenStarted, demoStep >= demoCastMarks.count, phase == .boating, worldDist >= demoKrakenAt {
+            demoKrakenStarted = true
+            startKraken()                                            // the finale rises after the last catch
+        }
+
+        if phase == .kraken {
+            let ct = krakenT - krakenIntro                          // <0 while it's still rising
+            if ct < 0 {
+                boatTargetX = 0.5
+            } else {
+                boatTargetX = 0.5 - 0.13 * cos(ct * 1.96)           // weave opposite the alternating tentacles
+                if ct - demoHarpoonLast >= 0.7 { demoHarpoonLast = ct; tap() }   // fire harpoons at the eyes
+            }
+        }
+    }
